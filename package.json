{
  "name": "droidmirror",
  "version": "1.1.0",
  "description": "Premium Android Mirroring & Control based on Scrcpy",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.nonsensys.droidmirror",
    "productName": "DroidMirror",
    "win": {
      "icon": "assets/icon.png",
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "scrcpy/",
        "to": "scrcpy/",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  }
}
